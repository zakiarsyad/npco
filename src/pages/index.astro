---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Heritage from '../components/sections/Heritage.astro';
import Services from '../components/sections/Services.astro';
import WhoWeHelp from '../components/sections/WhoWeHelp.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Certifications from '../components/sections/Certifications.astro';
import SocialProof from '../components/sections/SocialProof.astro';
import QuoteCta from '../components/sections/QuoteCta.astro';
---

<Base>
  <Header />
  <main id="main">
    <Hero />
    <Heritage />
    <Services />
    <WhoWeHelp />
    <HowItWorks />
    <Certifications />
    <SocialProof />
    <QuoteCta />
  </main>
  <Footer />
</Base>
