---
import { hero } from '../../data/site';
---

<section id="top" class="relative overflow-hidden bg-navy-950 text-white">
  <!-- image-free backdrop: layered navy gradients + grid + precision motif (no raster LCP) -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(125%_120%_at_12%_0%,#1b3358_0%,#12243c_42%,#0a1422_100%)]"></div>
  <div class="grid-motif pointer-events-none absolute inset-0 opacity-40"></div>
  <!-- subtle blueprint gauge motif, right side (cheap SVG, decorative) -->
  <svg
    class="pointer-events-none absolute -right-24 top-1/2 h-[140%] w-auto -translate-y-1/2 text-white/[0.05]"
    viewBox="0 0 400 400" fill="none" stroke="currentColor" aria-hidden="true"
  >
    <circle cx="200" cy="200" r="190" stroke-width="1" />
    <circle cx="200" cy="200" r="140" stroke-width="1" />
    <circle cx="200" cy="200" r="90" stroke-width="1" stroke-dasharray="4 8" />
    <path d="M10 200h380M200 10v380" stroke-width="1" />
  </svg>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-navy-950 to-transparent"></div>

  <div class="wrap relative grid items-center gap-12 pb-20 pt-36 md:pb-28 md:pt-44 lg:grid-cols-[1.15fr_0.85fr]">
    <div>
      <p class="eyebrow text-amber-400 [&::before]:bg-amber-400">Contract Manufacturing · Co-Packing</p>
      <h1 class="mt-5 max-w-[16ch] text-white text-[clamp(2.6rem,1.9rem+3.4vw,4.75rem)]">{hero.h1}</h1>
      <p class="mt-6 max-w-[54ch] text-lg text-white/75">{hero.sub}</p>
      <div class="mt-9 flex flex-wrap gap-4">
        <a href={hero.primaryCta.href} class="btn btn--primary group">
          {hero.primaryCta.label}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a href={hero.secondaryCta.href} class="btn btn--ghost">{hero.secondaryCta.label}</a>
      </div>
      <p class="mt-7 text-sm text-white/70">{hero.trust}</p>
    </div>

    <!-- capability panel with precision corner ticks -->
    <div class="relative rounded-3xl border border-white/15 bg-white/[0.05] p-6 shadow-[0_24px_60px_rgba(5,12,22,0.45)] backdrop-blur-sm sm:p-7">
      <span class="absolute left-4 top-4 size-3 border-l-2 border-t-2 border-amber-400"></span>
      <span class="absolute right-4 top-4 size-3 border-r-2 border-t-2 border-amber-400"></span>
      <span class="absolute bottom-4 left-4 size-3 border-b-2 border-l-2 border-amber-400"></span>
      <span class="absolute bottom-4 right-4 size-3 border-b-2 border-r-2 border-amber-400"></span>
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/65">All under one roof</p>
      <div class="mt-5 grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-white/10">
        {[
          { k: 'Mixing', v: '50–10,000 lb batches' },
          { k: 'Packaging', v: 'Pouch to pallet' },
          { k: 'Warehousing', v: '65,000 sq-ft' },
          { k: 'Fulfillment', v: 'LTL & FTL' },
        ].map((s) => (
          <div class="bg-navy-900/80 p-4">
            <div class="font-display text-base font-bold text-amber-400">{s.k}</div>
            <div class="mt-1 text-sm text-white/70">{s.v}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
