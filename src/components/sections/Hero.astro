---
import { Image } from 'astro:assets';
import { hero } from '../../data/site';
import factory from '../../assets/hero-factory.jpg';
---

<section id="top" class="relative overflow-hidden bg-navy-900 text-white">
  <!-- duotone factory backdrop -->
  <div class="duotone absolute inset-0">
    <Image src={factory} alt="" aria-hidden="true" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" fetchpriority="high" />
  </div>
  <div class="grid-motif pointer-events-none absolute inset-0 opacity-60"></div>
  <div class="pointer-events-none absolute -right-32 top-10 size-[34rem] rounded-full bg-amber-500/15 blur-3xl"></div>

  <div class="wrap relative grid items-center gap-12 pb-20 pt-36 md:pb-28 md:pt-44 lg:grid-cols-[1.15fr_0.85fr]">
    <div>
      <p class="eyebrow reveal text-amber-400 [&::before]:bg-amber-400">Contract Manufacturing · Co-Packing</p>
      <h1 class="reveal mt-5 max-w-[16ch] text-white text-[clamp(2.6rem,1.9rem+3.4vw,4.75rem)]" style="--reveal-delay:60ms">
        {hero.h1}
      </h1>
      <p class="reveal mt-6 max-w-[54ch] text-lg text-white/75" style="--reveal-delay:140ms">{hero.sub}</p>
      <div class="reveal mt-9 flex flex-wrap gap-4" style="--reveal-delay:220ms">
        <a href={hero.primaryCta.href} class="btn btn--primary group">
          {hero.primaryCta.label}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a href={hero.secondaryCta.href} class="btn btn--ghost">{hero.secondaryCta.label}</a>
      </div>
      <p class="reveal mt-7 text-sm text-white/55" style="--reveal-delay:300ms">{hero.trust}</p>
    </div>

    <!-- capability panel with precision corner ticks -->
    <div class="reveal relative rounded-3xl border border-white/12 bg-white/[0.06] p-6 backdrop-blur-md sm:p-7" style="--reveal-delay:260ms">
      <span class="absolute left-4 top-4 size-3 border-l-2 border-t-2 border-amber-400"></span>
      <span class="absolute right-4 top-4 size-3 border-r-2 border-t-2 border-amber-400"></span>
      <span class="absolute bottom-4 left-4 size-3 border-b-2 border-l-2 border-amber-400"></span>
      <span class="absolute bottom-4 right-4 size-3 border-b-2 border-r-2 border-amber-400"></span>
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/55">All under one roof</p>
      <div class="mt-5 grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-white/12">
        {[
          { k: 'Mixing', v: '50–10,000 lb batches' },
          { k: 'Packaging', v: 'Pouch to pallet' },
          { k: 'Warehousing', v: '65,000 sq-ft' },
          { k: 'Fulfillment', v: 'LTL & FTL' },
        ].map((s) => (
          <div class="bg-navy-900/70 p-4">
            <div class="font-display text-base font-bold text-amber-400">{s.k}</div>
            <div class="mt-1 text-sm text-white/70">{s.v}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
