---
import { personas } from '../../data/site';
---

<section id="who-we-help" class="section relative overflow-hidden bg-navy-900 text-white">
  <div class="grid-motif pointer-events-none absolute inset-0 opacity-40"></div>
  <div class="wrap relative">
    <p class="eyebrow reveal text-amber-400 [&::before]:bg-amber-400">Who We Help</p>
    <h2 class="reveal mt-3 max-w-[22ch] text-white text-[clamp(2rem,1.6rem+1.8vw,3.2rem)]">
      Built for the people scaling a food brand
    </h2>
    <p class="reveal mt-4 max-w-[56ch] text-lg text-white/70">
      Outgrown your co-packer, or bringing a new SKU to market? We plug in as an extension of your team.
    </p>

    <div class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-3xl border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
      {personas.map((p, i) => (
        <article class="reveal group bg-navy-900 p-7 transition-colors hover:bg-navy-800" style={`--reveal-delay:${i * 80}ms`}>
          <span class="font-display text-sm font-bold text-amber-400">0{i + 1}</span>
          <h3 class="mt-3 font-display text-lg text-white">{p.label}</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/65">{p.need}</p>
        </article>
      ))}
    </div>
  </div>
</section>
